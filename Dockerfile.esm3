# syntax=docker/dockerfile:1.7
# Image for FastPLMs ESM3 testing.
# Biohub `esm` is loaded from the official/esm submodule via sys.path.

FROM fastplms-base

RUN pip install \
        attrs==26.1.0 \
        biopython==1.87 \
        biotite==1.6.0 \
        brotli==1.2.0 \
        cloudpathlib==0.24.0 \
        httpx==0.28.1 \
        msgpack==1.1.2 \
        msgpack-numpy==0.4.8 \
        pandas==3.0.3 \
        pygtrie==2.5.0 \
        tenacity==9.1.4 \
        zstd==1.5.7.3
